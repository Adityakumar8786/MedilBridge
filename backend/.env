# MongoDB Connection (replace with your URI)
MONGO_URI=mongodb://localhost:27017/medilbridge

# Server Port
PORT=5000

# Session Secret (generate a strong one at random.org)
SESSION_SECRET=your_super_long_random_secret_key_here_make_it_32_chars

# Twilio for OTP (get from twilio.com dashboard)
TWILIO_SID=ACyour_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+your_twilio_phone_number_here